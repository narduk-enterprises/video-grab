{
  "name": "@loganrenz/nuxt-v4-template-layer",
  "version": "1.0.0",
  "type": "module",
  "description": "Narduk Nuxt 4 Layer — shared components, composables, server routes, and Drizzle schema for Cloudflare Workers apps",
  "repository": {
    "type": "git",
    "url": "https://github.com/loganrenz/narduk-nuxt-layer.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "4.5.0",
    "@nuxtjs/seo": "^3.4.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "postcss": "^8.5.6",
    "posthog-js": "^1.205.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@narduk/eslint-config": "*"
  },
  "peerDependenciesMeta": {
    "@narduk/eslint-config": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/lucide": "^1.2.94",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.19.13",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "nuxt": "^4.3.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@latest"
  },
  "files": [
    "app/",
    "components/",
    "server/",
    "drizzle/",
    "nuxt.config.ts",
    "tsconfig.json",
    "drizzle.config.ts"
  ],
  "volta": {
    "node": "22.22.0"
  }
}
