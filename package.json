{
  "name": "narduk-nuxt-template",
  "version": "1.9.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "predev": "node tools/check-setup.js",
    "dev": "pnpm --filter web dev",
    "prebuild": "node tools/check-setup.js",
    "build": "doppler run -- pnpm -r build",
    "predeploy": "node tools/check-setup.js",
    "deploy": "doppler run -- pnpm --filter web run deploy",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  Run pnpm run setup before doing anything else! See AGENTS.md.\\n')\"",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "prelint": "pnpm run build:plugins",
    "lint": "pnpm run prelint && turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality": "turbo run quality",
    "setup": "npx tsx tools/init.ts",
    "update-layer": "npx tsx tools/update-layer.ts",
    "sync-template": "npx tsx tools/sync-template.ts",
    "migrate-to-org": "npx tsx tools/migrate-to-org.ts",
    "validate": "doppler run -- npx tsx tools/validate.ts",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && pnpm install && pnpm run db:ready:all",
    "db:migrate": "pnpm --filter web run db:migrate",
    "dev:kill": "sh scripts/dev-kill.sh",
    "dev:showcase": "concurrently -n showcase,auth,blog,mkt,og,maps -c blue,green,yellow,magenta,white,gray \"pnpm --filter showcase dev\" \"sh scripts/run-dev-auth.sh\" \"pnpm --filter example-blog dev\" \"pnpm --filter example-marketing dev\" \"pnpm --filter example-og-image dev\" \"pnpm --filter example-apple-maps dev\"",
    "dev:auth": "pnpm --filter example-auth dev",
    "dev:blog": "pnpm --filter example-blog dev",
    "dev:marketing": "pnpm --filter example-marketing dev",
    "dev:og-image": "pnpm --filter example-og-image dev",
    "db:ready:all": "pnpm run db:ready:auth && pnpm run db:ready:blog",
    "db:ready:auth": "pnpm --filter example-auth run db:ready",
    "db:ready:blog": "pnpm --filter example-blog run db:ready",
    "db:migrate:auth": "pnpm --filter example-auth run db:migrate",
    "db:seed:auth": "pnpm --filter example-auth run db:seed",
    "build:showcase": "pnpm -r --filter 'example-*' --filter showcase build",
    "deploy:showcase": "pnpm -r --filter 'example-*' --filter showcase build && pnpm -r --filter 'example-*' --filter showcase exec wrangler deploy",
    "test:e2e": "playwright test",
    "test:e2e:auth": "pnpm --filter example-auth test:e2e",
    "test:e2e:blog": "pnpm --filter example-blog test:e2e",
    "test:e2e:marketing": "pnpm --filter example-marketing test:e2e",
    "test:e2e:showcase": "pnpm --filter showcase test:e2e",
    "dev:apple-maps": "pnpm --filter example-apple-maps dev",
    "test:e2e:apple-maps": "pnpm --filter example-apple-maps test:e2e",
    "generate:favicons": "npx tsx tools/generate-favicons.ts"
  },
  "pnpm": {
    "overrides": {
      "nuxt-og-image": "6.0.0-beta.42",
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.19.13",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12"
  }
}
