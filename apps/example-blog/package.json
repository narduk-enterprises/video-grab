{
  "name": "example-blog",
  "type": "module",
  "private": true,
  "version": "1.10.0",
  "scripts": {
    "build": "nuxt build",
    "db:ready": "pnpm run db:migrate && pnpm run db:seed",
    "db:migrate": "wrangler d1 execute narduk-nuxt-template-examples-db --local --file=node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle/0000_initial_schema.sql",
    "db:seed": "wrangler d1 execute narduk-nuxt-template-examples-db --local --file=node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle/seed.sql",
    "dev": "pnpm run db:ready && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck",
    "test:e2e": "playwright test --project=example-blog --config=../../playwright.config.ts"
  },
  "dependencies": {
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "@narduk/eslint-config": "workspace:*",
    "@nuxt/content": "^3.0.0",
    "@takumi-rs/core": "^0.69.5",
    "nuxt": "^4.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "eslint": "^10.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
