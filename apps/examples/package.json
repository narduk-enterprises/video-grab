{
  "name": "examples",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck",
    "db:migrate": "wrangler d1 execute nuxt-v4-template-examples-db --local --file=node_modules/@loganrenz/nuxt-v4-template-layer/drizzle/0000_initial_schema.sql",
    "db:seed": "wrangler d1 execute nuxt-v4-template-examples-db --local --file=node_modules/@loganrenz/nuxt-v4-template-layer/drizzle/seed.sql",
    "init": "jiti ../../tools/init.ts"
  },
  "dependencies": {
    "@narduk/eslint-config": "workspace:*",
    "@loganrenz/nuxt-v4-template-layer": "^1.0.0",
    "nuxt": "^4.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@latest"
  },
  "volta": {
    "node": "22.22.0"
  }
}
